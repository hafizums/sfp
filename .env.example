# Backend
# Safe local SQLite default. Do not commit real API keys.
DATABASE_URL=sqlite:///./short_film_planner.db

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8010/api

# OpenAI story package generation
# Use a real key only in your local environment. Never put this in frontend code.
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL_STORY=gpt-5-mini
OPENAI_STORY_TIMEOUT_SECONDS=120
OPENAI_MODEL_PROMPTS=gpt-5-mini
OPENAI_PROMPT_TIMEOUT_SECONDS=120

# WaveSpeed integration is intentionally not configured yet.
